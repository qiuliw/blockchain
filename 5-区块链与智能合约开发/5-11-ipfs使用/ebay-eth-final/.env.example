# Anvil 本地链 RPC
RPC_URL=http://127.0.0.1:8545

# Anvil 默认部署账户（私钥已知，仅用于本地开发）
DEPLOYER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# forge script 部署后填入合约地址
CONTRACT_ADDRESS=

# 同步到 frontend/.env 的 VITE_CONTRACT_ADDRESS（前端 Vite 使用）

# IPFS API（ipfs daemon，默认 5001）
IPFS_HOST=127.0.0.1
IPFS_API_PORT=5001
IPFS_PROTOCOL=http

# IPFS 网关（浏览器展示图片）
IPFS_GATEWAY_URL=http://127.0.0.1:8848
