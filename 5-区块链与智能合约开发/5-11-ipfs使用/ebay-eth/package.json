{
  "name": "ebay-eth",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:contract": "forge test",
    "build:contract": "forge build && node scripts/sync-abi.js",
    "deploy:local": "forge script script/DeployEcommerceStore.s.sol:DeployEcommerceStore --rpc-url http://127.0.0.1:8545 --broadcast",
    "dev": "NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server --config webpack.config.js",
    "build:webpack": "NODE_OPTIONS=--openssl-legacy-provider webpack-cli --config webpack.config.js"
  },
  "devDependencies": {
    "babel-core": "^6.26.3",
    "babel-loader": "^7.1.5",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "babel-plugin-transform-react-jsx": "^6.24.1",
    "babel-preset-env": "^1.7.0",
    "copy-webpack-plugin": "^4.6.0",
    "css-loader": "^0.28.11",
    "html-webpack-plugin": "^3.2.0",
    "sass": "^1.77.0",
    "sass-loader": "^7.3.1",
    "style-loader": "^0.23.1",
    "truffle-contract": "^4.0.7",
    "webpack": "^4.47.0",
    "webpack-cli": "^3.3.12",
    "webpack-dev-server": "^3.11.3"
  },
  "dependencies": {
    "jquery": "^3.7.1",
    "web3": "1.10.4"
  }
