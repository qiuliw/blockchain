{
  "name": "ebay-eth-final",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "test:contract": "forge test",
    "build:contract": "forge build && node scripts/sync-abi.js",
    "deploy:local": "dotenv -- forge script script/DeployEcommerceStore.s.sol:DeployEcommerceStore --rpc-url $RPC_URL --broadcast --sender $DEPLOYER_ADDRESS --unlocked",
    "dev": "pnpm -C frontend dev",
    "build": "pnpm -C frontend build",
    "preview": "pnpm -C frontend preview",
    "ipfs:start": "bash scripts/start-ipfs.sh",
    "frontend:install": "pnpm -C frontend install",
    "install:all": "pnpm install && pnpm -C frontend install"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2"
  }
}
